DirectoryIndex index.html
Options -MultiViews
ErrorDocument 404 /index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule . - [L]

  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_dir.c>
  FallbackResource /index.html
</IfModule>