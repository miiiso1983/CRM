# ============================================
# Al Team CRM - Environment Variables
# ============================================
# انسخ هذا الملف باسم .env وعدّل القيم حسب بيئتك

# ============ SERVER ============
PORT=5001
NODE_ENV=production

# ============ DATABASE (Cloudways) ============
# احصل على هذه القيم من: Cloudways → Application → Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=alteam_crm
DB_USER=YOUR_CLOUDWAYS_DB_USER
DB_PASS=YOUR_CLOUDWAYS_DB_PASSWORD

# ============ JWT ============
# استخدم سلسلة عشوائية طويلة (32+ حرف)
JWT_SECRET=AlTeam_CRM_Super_Secret_Key_2024_Change_This_In_Production
JWT_EXPIRE=7d

# ============ URLs ============
APP_URL=https://phpstack-1492540-6293582.cloudwaysapps.com
FRONTEND_URL=https://phpstack-1492540-6293582.cloudwaysapps.com

# ============ Firebase (اختياري - للإشعارات) ============
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ============ Email (اختياري) ============
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_email_app_password
MAIL_FROM=Al Team CRM <noreply@alteam.com>

