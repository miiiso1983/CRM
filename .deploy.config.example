# ============================================================
# Al Team CRM - SSH Deployment Config
# ============================================================
# 1. انسخ هذا الملف باسم .deploy.config
#    cp .deploy.config.example .deploy.config
#
# 2. عدّل القيم أدناه من Cloudways:
#    Application → SSH & SFTP
# ============================================================

# ===== SSH Connection =====
# من: Cloudways → Server → Master Credentials
SSH_HOST=your-server-ip-or-hostname       # مثال: 185.220.101.45
SSH_PORT=22                                # Cloudways عادة يستخدم منفذ مخصص مثل 58419
SSH_USER=master                            # المستخدم الافتراضي في Cloudways

# مسار مفتاح SSH الخاص بك على جهازك
SSH_KEY=~/.ssh/id_rsa                      # مثال: ~/.ssh/cloudways_key

# ===== Remote Paths =====
# من: Cloudways → Application → Application Details
# المسار الكامل لمجلد التطبيق (غير هذا ليطابق اسم تطبيقك)
REMOTE_APP_PATH=/home/master/applications/YOUR_APP_FOLDER_NAME

# إذا كان مسار الواجهة المقدم للعامة مختلفًا عن مسار الباكند، يمكنك تحديدهما صراحةً:
# REMOTE_FRONTEND_PATH=/home/APP_DOMAIN/APP_ID/public_html
# REMOTE_BACKEND_PATH=/home/master/applications/YOUR_APP_FOLDER_NAME/backend

# ===== Database (for .env on server) =====
# من: Cloudways → Application → Database
DB_NAME=alteam_crm
DB_USER=your_db_username
DB_PASS=your_db_password

# ===== Backend Settings =====
BACKEND_PORT=5001
JWT_SECRET=AlTeam_CRM_Super_Secret_Change_This_2024

